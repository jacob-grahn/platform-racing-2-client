<?xml version="1.0" encoding="utf-8"?>
<project>
	<meta title="Platform Racing 2" package="com.jiggmin.pr2" version="0.0.1" company="Jiggmin" />

	<app main="Main" path="export" file="PlatformRacing2" />

	<source path="haxe/src" />
	<assets path="assets" rename="assets" exclude="fonts/*" if="html5" />
	<assets path="assets" rename="assets" exclude="fonts/*" unless="html5" />

	<!-- Embedded fonts. Mapped to the original PR2 face names by pr2.runtime.FontResolver.
	     DejaVu Sans (Verdana stand-in, metric-compatible) is split into distinct family
	     names per weight so OpenFL's __fontByName variant lookup resolves bold/italic to the
	     real outlines instead of browser faux-synthesis. -->
	<assets path="assets/fonts" rename="assets/fonts" include="*.ttf" embed="true" />
	<assets path="vector-art/png/blocks" rename="assets/blocks" />
	<assets path="vector-art/atlases/character" rename="assets/character/atlases" />
	<assets path="vector-art/atlases/intro" rename="assets/intro/atlases" />
	<assets path="vector-art/png/login" rename="assets/login" />
	<assets path="vector-art/png/backgrounds" rename="assets/backgrounds" />
	<assets path="vector-art/png/stamps" rename="assets/stamps" />

	<haxelib name="openfl" />

	<window width="550" height="400" fps="27" background="#242A3A" resizable="false" />
</project>
