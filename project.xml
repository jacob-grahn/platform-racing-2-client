<?xml version="1.0" encoding="utf-8"?>
<project>
	<meta title="Platform Racing 2" package="com.jiggmin.pr2" version="0.0.1" company="Jiggmin" />

	<app main="Main" path="export" file="PlatformRacing2" />

	<source path="haxe/src" />
	<assets path="assets" rename="assets" exclude="fonts|blocks|login" if="html5" />
	<assets path="assets" rename="assets" exclude="fonts|blocks|login" unless="html5" />

	<!-- Embedded fonts. Mapped to the original PR2 face names by pr2.runtime.FontResolver.
	     DejaVu Sans (Verdana stand-in, metric-compatible) is split into distinct family
	     names per weight so OpenFL's __fontByName variant lookup resolves bold/italic to the
	     real outlines instead of browser faux-synthesis. -->
	<assets path="assets/fonts" rename="assets/fonts" include="*.ttf" embed="true" />
	<assets path="assets/blocks" rename="assets/blocks" />
	<!-- bg_front contains an embedded source bitmap in Animate's SVG export, so
	     it remains raster until the original artwork is replaced with vectors. -->
	<assets path="assets/login" rename="assets/login" include="bg_front@2x.png" />
	<!-- Animate-exported vectors are rendered directly by openfl/svg. Keeping the
	     source SVGs here also prevents derived PNG/WebP copies from entering export/. -->
	<assets path="art/svg" rename="assets/svg" include="*.svg" exclude="timeline|character" />
	<assets path="art/svg-packs/timeline" rename="assets/svg-packs/timeline" include="*.json" />
	<assets path="art/png/timeline" rename="assets/timeline-bitmap" include="*.png" />
	<!-- Native presentation slices reference only the leaf art they own, without
	     loading the generated XFL symbol catalog. -->
	<asset path="art/svg/timeline/ui_shadowbg_95643069a8/t00_l000_f0000_r00.svg" rename="assets/svg/timeline/ui_shadowbg_95643069a8/t00_l000_f0000_r00.svg" />
	<asset path="assets/bitmaps/mine.jpg" />
	<template path="templates/html5/template/index.html" rename="index.html" if="html5" />

	<haxelib name="openfl" />
	<haxelib name="svg" />
	<postbuild command="python3 tools/prune_html5_fonts.py" if="html5" />
	<postbuild command="python3 tools/minify_html5_js.py" if="html5" />
	<postbuild command="python3 tools/cache_bust_html5_js.py" if="html5" />

	<!-- Flatten static, render-safe display subtrees into one cached GPU quad
	     (pr2.runtime.FlattenPolicy gate + PR2MovieClip.maybeFlattenSubtree).
	     On by default: measured the lobby 18.7fps -> 60fps (vsync cap) with a
	     sub-perceptual (<=2/255) anti-alias delta. Both gates still run at
	     runtime, so only static+safe subtrees are ever cached. Remove this
	     define to A/B against the un-flattened render. -->
	<haxedef name="pr2_flatten_cache" />

	<window width="550" height="400" fps="27" background="#242A3A" resizable="true" if="html5" />
	<window width="550" height="400" fps="27" background="#242A3A" resizable="false" unless="html5" />
</project>
